# Server configuration
PORT=5000
NODE_ENV=development
JWT_SECRET=supersecretjwtsecretkeyshouldbechangedinproduction

# Database configuration (MongoDB)
DATABASE_URL="mongodb://localhost:27017/homerituals"

# Initial Admin details for database seeding
ADMIN_EMAIL=admin@homerituals.com
ADMIN_PASSWORD=AdminPassword123!
ADMIN_NAME="Home Rituals Admin"

# Cloudinary configuration (Media Uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Razorpay configuration (Payments)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# SMTP Email configuration (Transactional notifications)
# If left commented or blank, emails will print to the console instead
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=586
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_email_app_password
# EMAIL_FROM="Home Rituals <no-reply@homerituals.com>"
